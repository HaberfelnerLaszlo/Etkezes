@page "/"
@inject NavigationManager navi
<PageTitle>Kezdőlap</PageTitle>

<h1>Hello, world!</h1>
<FluentStack Orientation="Orientation.Horizontal"HorizontalAlignment="HorizontalAlignment.Start" HorizontalGap="30">
   <FluentButton OnClick="@(() => navi.NavigateTo("/loginusers"))" Style="width:150px; height:150px">
        <ChildContent>
            <FluentEmoji Value="@(new Emojis.PeopleBody.Color.Light.Student())" Width="128px" />
            <FluentLabel>Diákok</FluentLabel>
        </ChildContent>
    </FluentButton>
    <FluentButton OnClick="@(() => navi.NavigateTo("/users"))" Style="width:150px; height:150px">
        <ChildContent>
            <FluentEmoji Value="@(new Emojis.PeopleBody.Color.Light.Student())" Width="128px" />
            <FluentLabel>Diákok</FluentLabel>
        </ChildContent>
    </FluentButton>
    <FluentButton OnClick="@(() => navi.NavigateTo("/userstoetkezo"))" Style="width:150px; height:150px">
        <ChildContent>
            <FluentEmoji Value="@(new Emojis.PeopleBody.Color.Light.Cook())" Width="128px" />
            <FluentLabel>Étkezők</FluentLabel>
        </ChildContent>
    </FluentButton>
    <FluentButton OnClick="@(() => navi.NavigateTo("/etkezo"))" Style="width:150px; height:150px">
        <ChildContent>
            <FluentEmoji Value="@(new Emojis.PeopleBody.Color.Light.WomanGesturingNo())" Width="128px" />
            <FluentLabel>Étkezések</FluentLabel>
        </ChildContent>
    </FluentButton>
</FluentStack>