@inject IDialogService dialogService

<FluentDataGrid TGridItem="User" Items="Users.AsQueryable()" >
    <PropertyColumn Property="u => u.Name" Title="Nķv" />
    <PropertyColumn Property="u => u.Osztaly" Title="Osztßly" />
    <PropertyColumn Property="u => u.Etkezik" Title="╔tkezik?" />
    <TemplateColumn Title="M¹veletek">
        <FluentButton Appearance="Appearance.Accent" OnClick="@(() => EditUser(context))">Szerkesztķs</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="@(() => DeleteUser(context))">T÷rlķs</FluentButton>
    </TemplateColumn>
</FluentDataGrid>
<FluentButton OnClick="@(async ()=>await Save.InvokeAsync(Users))" Disabled="!IsEdited">Mentķs</FluentButton>
@code{
    [Parameter]
    public List<User> Users { get; set; } = new();
    [Parameter]
    public EventCallback<List<User>> Save { get; set; }
    [Parameter]
    public EventCallback<User> Delete { get; set; }

    bool IsEdited = false;

    private async void EditUser(User user)
    {
        DialogParameters parameters = new()
        {
            Title = $"{user.Name} adatai",
            TitleTypo = Typography.H4,
            // PrimaryAction = "Yes",
            // PrimaryActionEnabled = true,
            // SecondaryAction = "No",
            Width = "500px",
            Modal = true,
            PreventScroll = true
        };

        IDialogReference dialog = await dialogService.ShowDialogAsync<UserDialog>(user, parameters);
        DialogResult? result = await dialog.Result;

        if (result.Data is not null)
        {
            user = (User)result.Data;
            var updatingUser = Users.Find(u =>u.Id== user.Id);
            updatingUser = user;
        }
        //await Edit.InvokeAsync(user); 
    }
    private async void DeleteUser(User user) => await Delete.InvokeAsync(user);
}