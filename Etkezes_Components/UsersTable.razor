@inject IDialogService dialogService

<FluentDataGrid TGridItem="User" Items="Users.AsQueryable()" ShowHover="true" Pagination="pagination" Style="overflow-y:hidden;">
    <PropertyColumn Property="u => u.Name" Title="N�v" />
    <PropertyColumn Property="u => u.Osztaly" Title="Oszt�ly" />
    <PropertyColumn Property="u => u.Etkezik" Title="�tkezik?" />
    <PropertyColumn Property="u => u.FpId" Title="Azonosító" />
    <PropertyColumn Property="@(u => string.IsNullOrEmpty(u.FingerPrint1) ? "Nincs" : "Van")" Title="Ujj_1" />
    <PropertyColumn Property="@(u => string.IsNullOrEmpty(u.FingerPrint2) ? "Nincs" : "Van")" Title="Ujj_2" />
    <TemplateColumn Title="Műveletek">
        <FluentButton Appearance="Appearance.Accent" OnClick="@(() => EditUser(context))">Szerkeszts</FluentButton>
        <FluentButton Appearance="Appearance.Accent" OnClick="@(() => DeleteUser(context))">TTrls</FluentButton>
    </TemplateColumn>
</FluentDataGrid>
<FluentPaginator State="@pagination" />
@* <FluentButton OnClick="@(async ()=>await Save.InvokeAsync(Users))" Disabled="!IsEdited">Ment�s</FluentButton> *@

@code{
    [Parameter]
    public List<User> Users { get; set; } = new();
    // [Parameter]
    // public EventCallback<List<User>> Save { get; set; }
    [Parameter]
    public EventCallback<User> Save { get; set; }
    [Parameter]
    public EventCallback<User> Delete { get; set; }
    PaginationState pagination = new PaginationState { ItemsPerPage = 8 };
    bool IsEdited = false;

    private async void EditUser(User user)
    {
        DialogParameters parameters = new()
        {
            Title = $"{user.Name} adatai",
            TitleTypo = Typography.H4,
            Width = "500px",
            Modal = true,
            PreventScroll = true
        };

        IDialogReference dialog = await dialogService.ShowDialogAsync<UserDialog>(user, parameters);
        DialogResult? result = await dialog.Result;

        if (result.Data is not null)
        {
            user = (User)result.Data;
            var updatingUser = Users.Find(u =>u.Id== user.Id);
            updatingUser = user;
        }
        StateHasChanged();
        await Save.InvokeAsync(user); 
    }
    private async void DeleteUser(User user) => await Delete.InvokeAsync(user);
}