@page "/LoginUsers"
@inject LoginUserService loginService

<h3>LoginUsers</h3>
@if(users.Count()== 0)
{
    <p>Nincs elmentett felhasználó.</p>
}
else
{
    <FluentDataGrid Items="@users" AutoFit="true">
        <PropertyColumn Property="u => u.Name" Title="Név" />
        <PropertyColumn Property="u => u.UserName" Title="Felhasználónév" />
        <PropertyColumn Property="u => u.Role" Title="Szerepkör" />
        <PropertyColumn Property="u => u.FpId" Title="FP Id" />
        <PropertyColumn Property="@((u) => String.IsNullOrWhiteSpace(u.FingerPrint1)?"Nincs":"Van")" Title="1. Ujj" />
        <PropertyColumn Property="@((u) => String.IsNullOrWhiteSpace(u.FingerPrint2)?"Nincs":"Van")" Title="2. Ujj" />
 @*        <PropertyColumn Property="u => u.FingerPrint1.Substring(0, 10)" Title="1. Ujjlenyomat" />
        <PropertyColumn Property="u => u.FingerPrint2.Substring(0, 10)" Title="2. Ujjlenyomat" />
        <PropertyColumn Property="u => u.Password.ToString()" Title="Jelszó_Hash" />*@
        <PropertyColumn Property="u => u.UpdatedAt.ToString()" Title="Utolsó frissítés" />
        <TemplateColumn Title="Műveletek">
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => EditUser(context))">Szerkesztés</FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => DeleteUser(context))">Törlés</FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick="@(() => Fingerprint(context))">Ujj</FluentButton>
        </TemplateColumn>
    </FluentDataGrid>
}

@code {
    IQueryable<LoginUser> users = new List<LoginUser>().AsQueryable();
    protected override async Task OnInitializedAsync()
    {
        users = loginService.GetAllUsers().AsQueryable();
    }
